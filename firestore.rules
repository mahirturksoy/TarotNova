rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: User authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function: User owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Readings collection - User can only access their own readings
    match /readings/{readingId} {
      // Read: Only if user owns the reading
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Create: Only if setting userId to their own ID
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Update: Only if user owns the reading and not changing userId
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == request.auth.uid;

      // Delete: Only if user owns the reading
      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    // Users collection - User can only access their own user document
    match /users/{userId} {
      // Read: Only own user document
      allow read: if isOwner(userId);

      // Create: Only own user document
      allow create: if isOwner(userId);

      // Update: Only own user document
      allow update: if isOwner(userId);

      // Delete: Only own user document (rarely needed)
      allow delete: if isOwner(userId);
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
